rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user owns the document
    function isOwner(userId) {
      return request.auth.uid == userId || userId == "anonymous";
    }

    // Generic match for all documents to allow temporary access (testing)
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 4, 3);
    }

    // Explicit callSessions match for clarity
    match /callSessions/{sessionId} {
      allow read, write: if request.time < timestamp.date(2026, 4, 3);
    }

    // Products collection
    match /products/{productId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Personas collection
    match /personas/{personaId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // Sessions collection
    match /sessions/{sessionId} {
      allow read, update, delete: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
    }

    // UserMetrics collection
    match /userMetrics/{userId} {
      allow read, write: if isAuthenticated() && isOwner(userId);
    }
  }
}
